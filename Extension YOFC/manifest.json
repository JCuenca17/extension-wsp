{
    "manifest_version": 3,
    "name": "YOFC Cloud Manager",
    "version": "1.0",
    "description": "Herramienta On-Demand para YOFC",
    "icons": {
        "48": "logo.png",
        "128": "logo.png"
    },
    "action": {
        "default_icon": {
            "48": "logo.png",
            "128": "logo.png"
        }
    },
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://script.google.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://web.whatsapp.com/*"
            ],
            "js": [
                "yofc_script.js"
            ]
        }
    ]
}