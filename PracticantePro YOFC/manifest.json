{
  "manifest_version": 3,
  "name": "Yofc injector",
  "version": "10.0",
  "description": "Sistema Flat Corporate de extracción e inyección.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png"
  },
  "permissions": ["storage", "unlimitedStorage"],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["whatsapp_capture.js"],
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["yofc_logic.js", "yofc_ui.js"],
      "all_frames": true
    }
  ]
}